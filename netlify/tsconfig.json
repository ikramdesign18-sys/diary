{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "typeRoots": ["../artifacts/api-server/node_modules/@types", "../node_modules/@types"]
  },
  "include": ["functions/**/*.ts", "functions/**/*.mts", "../artifacts/api-server/src/services/**/*.ts", "../artifacts/api-server/src/utils/**/*.ts"]
}
